# ============================================================
# Variáveis de ambiente — copie este arquivo para .env
# e preencha com os valores reais (nunca commite o .env)
# ============================================================

# PostgreSQL
POSTGRES_DB=backend_contratos
POSTGRES_USER=postgres
POSTGRES_PASSWORD=sua_senha_aqui

# Conexão com o banco (used pelo Spring Boot)
DB_URL=jdbc:postgresql://localhost:5432/backend_contratos
DB_USERNAME=postgres
DB_PASSWORD=sua_senha_aqui

# JWT — gere uma chave Base64 de pelo menos 32 bytes:
# $ openssl rand -base64 32
JWT_SECRET=sua_chave_base64_aqui

